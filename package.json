{
  "name": "lms",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.126",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-scripts": "5.0.1",
    "typescript": "^5.9.3",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:ci": "cross-env CI=true react-scripts test --coverage --watchAll=false",
    "test:coverage": "react-scripts test --coverage --watchAll=false",
    "eject": "react-scripts eject",
    "prepare": "husky",
    "lint": "npm-run-all lint:js lint:css",
    "lint:js": "eslint src --ext .ts,.tsx,.js,.jsx",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:fix": "npm-run-all lint:fix:*",
    "lint:fix:js": "eslint src --ext .ts,.tsx,.js,.jsx --fix",
    "lint:fix:css": "stylelint \"src/**/*.css\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "secretlint": "secretlint \"**/*\"",
    "validate": "npm-run-all type-check lint format:check secretlint test:ci build",
    "clean": "rm -rf build node_modules/.cache",
    "docker:build": "docker build -t lms:latest .",
    "docker:run": "docker run -p 3000:80 lms:latest",
    "docker:dev": "docker-compose up dev",
    "docker:prod": "docker-compose up app",
    "verify": "bash scripts/verify-setup.sh"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@secretlint/quick-start": "^11.4.0",
    "@secretlint/secretlint-rule-preset-recommend": "^11.4.0",
    "@testing-library/react-hooks": "^8.0.1",
    "cross-env": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "stylelint": "^17.5.0",
    "stylelint-config-prettier": "^9.0.5",
    "stylelint-config-standard": "^40.0.0"
  }
}
